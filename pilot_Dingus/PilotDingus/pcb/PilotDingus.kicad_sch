  (text "The Pi Pico has a 200Ω\nresistor between 3V3 and\nADC_AVDD already. This\nmeans only an external\nshunt reference is needed\nto generate a different\nanalog reference voltage."
    (at 91.44 46.99 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 6a0698d7-d51e-48d0-9d12-b72a70cfbb79)
  )
  (text "RP2040 logic low 0.8V\nLogic high 2.0V\nPilot signal while oscillating\nwill be -12V low, 3V to 9V high.\nNeed a 2x gain in order to\nreliably trigger GPIO interrupt."
    (at 138.43 121.92 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid bb076c2e-2e25-44ae-8c75-09fccf6b7d7d)
  )

